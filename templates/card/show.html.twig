{% extends 'base.html.twig' %}

{% macro render_value(value) %}
    {% import _self as cardMacros %}

    {% if value is iterable %}
        <dl class="detail-list nested-list">
            {% for key, nestedValue in value %}
                <div>
                    <dt>{{ key|replace({'_': ' '})|title }}</dt>
                    <dd>{{ cardMacros.render_value(nestedValue) }}</dd>
                </div>
            {% endfor %}
        </dl>
    {% elseif value is same as(null) %}
        <span class="muted">{{ 'common.na'|trans }}</span>
    {% elseif value is same as(true) or value is same as(false) %}
        {{ value ? 'common.yes'|trans : 'common.no'|trans }}
    {% else %}
        {{ value }}
    {% endif %}
{% endmacro %}

{% import _self as cardMacros %}

{% block title %}{{ card.name_numbered ?? card.name }}{% endblock %}

{% block body %}
<a class="back-link" href="{{ path('cards') }}">{{ 'cards.back'|trans }}</a>

<section class="detail-hero">
    <div>
        {% if card.image is defined and card.image %}
            <img class="detail-image" src="{{ card.image }}" alt="{{ card.name_numbered ?? card.name }}">
        {% endif %}
    </div>

    <div class="detail-summary">
        <p class="eyebrow">{{ card.episode.name ?? 'One Piece' }}</p>
        <h1>{{ card.name_numbered ?? card.name }}</h1>

        <div class="card-tags">
            {% if card.rarity is defined and card.rarity %}<span>{{ card.rarity }}</span>{% endif %}
            {% if card.card_number is defined and card.card_number %}<span>{{ card.card_number }}</span>{% endif %}
            {% if card.version is defined and card.version %}<span>{{ card.version }}</span>{% endif %}
        </div>

        <dl class="detail-list">
            <div><dt>{{ 'card.fields.name'|trans }}</dt><dd>{{ card.name ?? 'common.na'|trans }}</dd></div>
            <div><dt>{{ 'card.fields.number'|trans }}</dt><dd>{{ card.card_number ?? 'common.na'|trans }}</dd></div>
            <div><dt>{{ 'card.fields.set'|trans }}</dt><dd>{{ card.episode.name ?? 'common.na'|trans }}</dd></div>
            <div><dt>{{ 'card.fields.set_code'|trans }}</dt><dd>{{ card.episode.code ?? 'common.na'|trans }}</dd></div>
            <div><dt>{{ 'card.fields.rarity'|trans }}</dt><dd>{{ card.rarity ?? 'common.na'|trans }}</dd></div>
            <div><dt>{{ 'card.fields.average_near_mint'|trans }}</dt><dd>{{ card.average_near_mint_price is not null ? '€' ~ card.average_near_mint_price : 'common.na'|trans }}</dd></div>
            <div><dt>{{ 'card.fields.languages'|trans }}</dt><dd>{{ card.languages is not empty ? card.languages|join(', ') : 'common.na'|trans }}</dd></div>
        </dl>
    </div>
</section>

<section class="detail-panel comments-panel" id="card-discussion">
    <h2>{{ 'discussion.heading'|trans }}</h2>
    <p class="muted">{{ 'discussion.intro'|trans }}</p>

    <div
        class="discussion-shell"
        data-card-discussion
        data-comments-url="{{ path('card_comments', { id: card.id }) }}"
        data-default-discussion="{{ cardCommentOptions.defaultDiscussionType }}"
        data-default-language="{{ cardCommentOptions.defaultLanguage }}"
        data-initial-comments="{{ initialComments|json_encode|e('html_attr') }}"
        data-no-comments-text="{{ 'discussion.no_comments'|trans }}"
        data-status-loading="{{ 'discussion.status.loading'|trans({'%topic%': '__TOPIC__', '%language%': '__LANGUAGE__'}) }}"
        data-status-showing="{{ 'discussion.status.showing'|trans({'%topic%': '__TOPIC__', '%language%': '__LANGUAGE__'}) }}"
        data-status-posting="{{ 'discussion.status.posting'|trans({'%topic%': '__TOPIC__', '%language%': '__LANGUAGE__'}) }}"
        data-error-load="{{ 'discussion.error.load'|trans }}"
        data-error-post="{{ 'discussion.error.post'|trans }}"
    >
        <div class="discussion-toolbar">
            <label class="discussion-select">
                {{ 'discussion.topic_label'|trans }}
                <select data-card-discussion-type>
                    {% for key, label in cardCommentOptions.discussionTypes %}
                        <option value="{{ key }}" {% if key == cardCommentOptions.defaultDiscussionType %}selected{% endif %}>{{ label }}</option>
                    {% endfor %}
                </select>
            </label>

            <div class="discussion-languages">
                <p>{{ 'discussion.language'|trans }}</p>
                <div class="language-button-row">
                    {% for language in cardCommentOptions.languages %}
                        <button
                            type="button"
                            class="language-button{% if language.key == cardCommentOptions.defaultLanguage %} is-active{% endif %}"
                            data-card-language-button
                            data-language="{{ language.key }}"
                        >
                            {{ language.label }}
                        </button>
                    {% endfor %}
                </div>
            </div>
        </div>

        <p class="muted" data-card-discussion-status>
            {{ 'discussion.status.showing'|trans({'%topic%': cardCommentOptions.discussionTypes[cardCommentOptions.defaultDiscussionType], '%language%': cardCommentOptions.languages|first.label}) }}
        </p>

        <form class="comment-form" data-card-discussion-form>
            <input type="hidden" name="_token" value="{{ csrf_token('card_comment_' ~ card.id) }}">
            <input type="hidden" name="discussion_type" value="{{ cardCommentOptions.defaultDiscussionType }}" data-card-discussion-type-input>
            <input type="hidden" name="language" value="{{ cardCommentOptions.defaultLanguage }}" data-card-discussion-language-input>
            <label>
                {{ 'comments.display_name'|trans }}
                <input type="text" value="{{ commentAuthorName }}" readonly>
            </label>
            <label>
                {{ 'comments.your_comment'|trans }}
                <textarea name="content" rows="4" maxlength="2000" minlength="3" required placeholder="{{ 'card.comment.placeholder'|trans({'%card%': card.name_numbered ?? card.name}) }}"></textarea>
            </label>
            <button type="submit">{{ 'comments.post'|trans }}</button>
        </form>

        <div class="comment-list" data-card-comments>
            {% for comment in initialComments %}
                <article class="comment-item">
                    <p>{{ comment.content }}</p>
                    <small>{{ comment.authorName }} - {{ comment.createdAt }}</small>
                </article>
            {% else %}
                <p class="muted">{{ 'discussion.no_comments'|trans }}</p>
            {% endfor %}
        </div>
    </div>
</section>

<section class="detail-grid">
    <article class="detail-panel">
        <h2>{{ 'card.info.heading'|trans }}</h2>
        <dl class="detail-list">
            <div><dt>{{ 'card.fields.name'|trans }}</dt><dd>{{ card.name ?? 'common.na'|trans }}</dd></div>
            <div><dt>{{ 'card.fields.number'|trans }}</dt><dd>{{ card.card_number ?? 'common.na'|trans }}</dd></div>
            <div><dt>{{ 'card.fields.rarity'|trans }}</dt><dd>{{ card.rarity ?? 'common.na'|trans }}</dd></div>
            <div><dt>{{ 'card.fields.version'|trans }}</dt><dd>{{ card.version ?? 'common.na'|trans }}</dd></div>
            <div><dt>{{ 'card.fields.average_near_mint'|trans }}</dt><dd>{{ card.average_near_mint_price is not null ? '€' ~ card.average_near_mint_price : 'common.na'|trans }}</dd></div>
            <div><dt>{{ 'card.fields.price_updated'|trans }}</dt><dd>{{ card.price_updated_at ? card.price_updated_at|date('Y-m-d H:i') : 'common.na'|trans }}</dd></div>
            <div><dt>{{ 'card.fields.languages'|trans }}</dt><dd>{{ card.languages is not empty ? card.languages|join(', ') : 'common.na'|trans }}</dd></div>
            <div><dt>{{ 'card.fields.source'|trans }}</dt><dd>{{ card.source ?? 'CardTrader' }}</dd></div>
        </dl>
    </article>

    <article class="detail-panel">
        <h2>{{ 'card.set.heading'|trans }}</h2>
        {{ cardMacros.render_value(card.episode ?? {}) }}
    </article>

    <article class="detail-panel">
        <h2>{{ 'card.external_ids.heading'|trans }}</h2>
        <dl class="detail-list">
            <div><dt>{{ 'card.external_ids.cardtrader'|trans }}</dt><dd>{{ card.id }}</dd></div>
            <div><dt>{{ 'card.external_ids.tcgplayer'|trans }}</dt><dd>{{ card.tcgplayer_id ?? 'common.na'|trans }}</dd></div>
            <div><dt>{{ 'card.external_ids.cardmarket'|trans }}</dt><dd>{{ card.cardmarket_id ?? 'common.na'|trans }}</dd></div>
        </dl>
    </article>
</section>
{% endblock %}
