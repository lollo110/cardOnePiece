{% if error %}
    <p class="message">{{ error }}</p>
{% endif %}

{% if (query or rarity or collection) and results is empty and not error %}
    <p class="message">{{ 'cards.empty'|trans }}</p>
{% endif %}

{% if rarityOptions is not empty or collectionOptions is not empty %}
    <section class="collection-tools">
        <p>
            {{ 'cards.total'|trans({'%count%': totalResults}) }}
            {% if rarity or collection %}
                - {{ 'cards.filtered'|trans }}
            {% else %}
                - {{ 'cards.page_count'|trans({'%current%': paging.current, '%total%': paging.total}) }}
            {% endif %}
        </p>

        <div class="filter-form">
            <label>
                {{ 'cards.filter.rarity'|trans }}
                <select data-card-filter="rarity">
                    <option value="">{{ 'cards.filter.all_rarities'|trans }}</option>
                    {% for rarityOption in rarityOptions %}
                        <option value="{{ rarityOption }}" {% if rarityOption == rarity %}selected{% endif %}>{{ rarityOption }}</option>
                    {% endfor %}
                </select>
            </label>

            <label>
                {{ 'cards.filter.collection'|trans }}
                <select data-card-filter="collection">
                    <option value="">{{ 'cards.filter.all_collections'|trans }}</option>
                    {% for collectionOption in collectionOptions %}
                        <option value="{{ collectionOption.value }}" {% if collectionOption.value == collection %}selected{% endif %}>{{ collectionOption.label }}</option>
                    {% endfor %}
                </select>
            </label>

            <button type="button" data-card-filter-reset>{{ 'cards.filter.reset'|trans }}</button>
        </div>
    </section>
{% endif %}

<section class="card-grid" data-card-grid>
    {% for card in results %}
        <article class="card-item" data-rarity="{{ card.rarity ?? '' }}">
            {% if card.image is defined and card.image %}
                <img class="card-image" src="{{ card.image }}" alt="{{ card.name_numbered ?? card.name }}" loading="lazy">
            {% endif %}

            <div class="card-content">
                <h2>
                    <a href="{{ path('card_show', { id: card.id, name: card.name_numbered ?? card.name }) }}">
                        {{ card.name_numbered ?? card.name }}
                    </a>
                </h2>

                {% if card.episode.name is defined %}
                    <p>{{ card.episode.name }}</p>
                {% endif %}

                <div class="card-tags">
                    {% if card.rarity is defined and card.rarity %}
                        <span>{{ card.rarity }}</span>
                    {% endif %}

                    {% if card.color is defined and card.color %}
                        <span>{{ card.color }}</span>
                    {% endif %}

                    {% if card.version is defined and card.version %}
                        <span>{{ card.version }}</span>
                    {% endif %}
                </div>

                <a class="card-detail-link" href="{{ path('card_show', { id: card.id, name: card.name_numbered ?? card.name }) }}">{{ 'card.view'|trans }}</a>
            </div>
        </article>
    {% endfor %}
</section>

{% if paging.total > 1 and not rarity and not collection %}
    <nav class="pagination" aria-label="{{ 'cards.pagination.aria'|trans }}">
        {% set pageParams = { q: query, sort: sort } %}

        {% if paging.current > 1 %}
            <a href="{{ path('cards', pageParams|merge({ page: 1 })) }}">{{ 'cards.pagination.first'|trans }}</a>
            <a href="{{ path('cards', pageParams|merge({ page: paging.current - 1 })) }}">{{ 'cards.pagination.previous'|trans }}</a>
        {% else %}
            <span>{{ 'cards.pagination.first'|trans }}</span>
            <span>{{ 'cards.pagination.previous'|trans }}</span>
        {% endif %}

        <span>{{ 'cards.pagination.summary'|trans({'%current%': paging.current, '%total%': paging.total}) }}</span>

        {% if paging.current < paging.total %}
            <a href="{{ path('cards', pageParams|merge({ page: paging.current + 1 })) }}">{{ 'cards.pagination.next'|trans }}</a>
            <a href="{{ path('cards', pageParams|merge({ page: paging.total })) }}">{{ 'cards.pagination.last'|trans }}</a>
        {% else %}
            <span>{{ 'cards.pagination.next'|trans }}</span>
            <span>{{ 'cards.pagination.last'|trans }}</span>
        {% endif %}
    </nav>
{% endif %}
