{% extends 'base.html.twig' %}

{% block title %}Recherche One Piece{% endblock %}

{% block body %}
<section class="search-section">
    <h1>Collection One Piece</h1>

    <form method="get" class="search-form" id="collection-options">
        <input type="hidden" name="q" value="{{ query }}">
        {% if rarity %}
            <input type="hidden" name="rarity" value="{{ rarity }}">
        {% endif %}
        <select name="sort" aria-label="Sort cards">
            <option value="relevance" {% if sort == 'relevance' %}selected{% endif %}>Relevance</option>
            <option value="recent" {% if sort == 'recent' %}selected{% endif %}>Recently updated</option>
            <option value="name_desc" {% if sort == 'name_desc' %}selected{% endif %}>Name Z-A</option>
        </select>
        <button>Rechercher</button>
    </form>
</section>

<div
    data-card-results
    data-filter-url="{{ path('cards_filter') }}"
    data-query="{{ query }}"
    data-sort="{{ sort }}"
    data-rarity="{{ rarity }}"
>
    {% include 'card/_results.html.twig' with {
        results: results,
        query: query,
        sort: sort,
        rarity: rarity,
        paging: paging,
        totalResults: totalResults,
        error: error,
        rarityOptions: rarityOptions,
    } only %}
</div>
{% endblock %}
