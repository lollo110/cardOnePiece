{% extends 'base.html.twig' %}

{% block title %}{{ 'cards.page_title'|trans }}{% endblock %}

{% block body %}
<section class="search-section">
    <h1>{{ 'cards.heading'|trans }}</h1>

    <form method="get" class="search-form" id="collection-options">
        <input type="hidden" name="q" value="{{ query }}">
        {% if rarity %}
            <input type="hidden" name="rarity" value="{{ rarity }}">
        {% endif %}
        {% if collection %}
            <input type="hidden" name="collection" value="{{ collection }}">
        {% endif %}
        <select name="sort" aria-label="{{ 'cards.sort.label'|trans }}">
            <option value="relevance" {% if sort == 'relevance' %}selected{% endif %}>{{ 'cards.sort.relevance'|trans }}</option>
            <option value="recent" {% if sort == 'recent' %}selected{% endif %}>{{ 'cards.sort.recent'|trans }}</option>
            <option value="name_desc" {% if sort == 'name_desc' %}selected{% endif %}>{{ 'cards.sort.name_desc'|trans }}</option>
        </select>
        <button>{{ 'cards.update_view'|trans }}</button>
    </form>
</section>

<div
    data-card-results
    data-filter-url="{{ path('cards_filter') }}"
    data-query="{{ query }}"
    data-sort="{{ sort }}"
    data-rarity="{{ rarity }}"
    data-collection="{{ collection }}"
>
    {% include 'card/_results.html.twig' with {
        results: results,
        query: query,
        sort: sort,
        rarity: rarity,
        collection: collection,
        paging: paging,
        totalResults: totalResults,
        error: error,
        rarityOptions: rarityOptions,
        collectionOptions: collectionOptions,
    } only %}
</div>
{% endblock %}
