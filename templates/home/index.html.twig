{% extends 'base.html.twig' %}

{% block title %}{{ 'site.name'|trans }}{% endblock %}

{% block body %}
<section class="home-hero">
    <p class="eyebrow">{{ 'site.name'|trans }}</p>
    <h1>{{ 'home.hero.title'|trans }}</h1>
    <p>{{ 'home.hero.description'|trans }}</p>
</section>

<section class="home-section">
    <div class="section-heading">
        <div>
            <p class="eyebrow">{{ 'nav.collection'|trans }}</p>
            <h2>{{ 'home.recent.title'|trans }}</h2>
        </div>
        <a href="{{ path('cards', { sort: 'recent' }) }}">{{ 'home.recent.link'|trans }}</a>
    </div>

    <section class="card-grid" data-card-grid>
        {% for card in recentCards %}
            <article class="card-item" data-rarity="{{ card.rarity ?? '' }}">
                {% if card.image is defined and card.image %}
                    <img class="card-image" src="{{ card.image }}" alt="{{ card.name_numbered ?? card.name }}" loading="lazy">
                {% endif %}

                <div class="card-content">
                    <h2>
                        <a href="{{ path('card_show', { id: card.id, name: card.name_numbered ?? card.name }) }}">
                            {{ card.name_numbered ?? card.name }}
                        </a>
                    </h2>

                    {% if card.episode.name is defined %}
                        <p>{{ card.episode.name }}</p>
                    {% endif %}

                    <div class="card-tags">
                        {% if card.rarity is defined and card.rarity %}<span>{{ card.rarity }}</span>{% endif %}
                        {% if card.version is defined and card.version %}<span>{{ card.version }}</span>{% endif %}
                    </div>

                    <a class="card-detail-link" href="{{ path('card_show', { id: card.id, name: card.name_numbered ?? card.name }) }}">{{ 'card.view'|trans }}</a>
                </div>
            </article>
        {% endfor %}
    </section>
</section>

<section class="home-section">
    <div class="section-heading">
        <div>
            <p class="eyebrow">{{ 'blog.section'|trans }}</p>
            <h2>{{ 'home.rooms.title'|trans }}</h2>
        </div>
        <a href="{{ path('blog') }}">{{ 'home.rooms.link'|trans }}</a>
    </div>

    <div class="topic-grid">
        {% for topic in topics %}
            <article class="detail-panel topic-card">
                <h3>{{ topic.title }}</h3>
                <p>{{ topic.description }}</p>
                <a class="card-detail-link" href="{{ path('blog_topic', { slug: topic.slug }) }}">{{ topic.button }}</a>
            </article>
        {% endfor %}
    </div>
</section>
{% endblock %}
