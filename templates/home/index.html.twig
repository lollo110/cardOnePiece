{% extends 'base.html.twig' %}

{% block title %}Pirate Card Blog{% endblock %}

{% block body %}
<section class="home-hero">
    <p class="eyebrow">Pirate Card Blog</p>
    <h1>Browse cards and join the conversation.</h1>
    <p>Search from the header, explore the collection, then jump into the discussion rooms or comment on a card page.</p>
</section>

<section class="home-section">
    <div class="section-heading">
        <div>
            <p class="eyebrow">Collection</p>
            <h2>Recently updated cards</h2>
        </div>
        <a href="{{ path('cards', { sort: 'recent' }) }}">View collection</a>
    </div>

    <section class="card-grid" data-card-grid>
        {% for card in recentCards %}
            <article class="card-item" data-rarity="{{ card.rarity ?? '' }}">
                {% if card.image is defined and card.image %}
                    <img class="card-image" src="{{ card.image }}" alt="{{ card.name_numbered ?? card.name }}" loading="lazy">
                {% endif %}

                <div class="card-content">
                    <h2>
                        <a href="{{ path('card_show', { id: card.id, name: card.name_numbered ?? card.name }) }}">
                            {{ card.name_numbered ?? card.name }}
                        </a>
                    </h2>

                    {% if card.episode.name is defined %}
                        <p>{{ card.episode.name }}</p>
                    {% endif %}

                    <div class="card-tags">
                        {% if card.rarity is defined and card.rarity %}<span>{{ card.rarity }}</span>{% endif %}
                        {% if card.version is defined and card.version %}<span>{{ card.version }}</span>{% endif %}
                    </div>

                    <a class="card-detail-link" href="{{ path('card_show', { id: card.id, name: card.name_numbered ?? card.name }) }}">Details</a>
                </div>
            </article>
        {% endfor %}
    </section>
</section>

<section class="home-section">
    <div class="section-heading">
        <div>
            <p class="eyebrow">Discussion</p>
            <h2>Blog rooms</h2>
        </div>
        <a href="{{ path('blog') }}">Open blog</a>
    </div>

    <div class="topic-grid">
        {% for topic in topics %}
            <article class="detail-panel topic-card">
                <h3>{{ topic.title }}</h3>
                <p>{{ topic.description }}</p>
                <a class="card-detail-link" href="{{ path('blog_topic', { slug: topic.slug }) }}">Open discussion</a>
            </article>
        {% endfor %}
    </div>
</section>
{% endblock %}
