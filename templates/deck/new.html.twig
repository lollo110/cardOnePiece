{% extends 'base.html.twig' %}

{% block title %}{{ 'deck.new'|trans }}{% endblock %}

{% block body %}
<a class="back-link" href="{{ path('decks') }}">{{ 'deck.back'|trans }}</a>

<section class="detail-panel deck-form-panel">
    <p class="eyebrow">{{ 'nav.decks'|trans }}</p>
    <h1>{{ 'deck.new'|trans }}</h1>
    <p class="muted">{{ 'deck.builder.help'|trans }}</p>

    <form class="deck-form" method="post">
        <input type="hidden" name="_token" value="{{ csrf_token('deck_new') }}">

        <label>
            <span>{{ 'deck.title'|trans }}</span>
            <input type="text" name="title" value="{{ form.title }}" required maxlength="160">
        </label>

        <label>
            <span>{{ 'deck.archetype'|trans }}</span>
            <input type="text" name="archetype" value="{{ form.archetype }}" maxlength="120">
        </label>

        <label>
            <span>{{ 'deck.visibility'|trans }}</span>
            <select name="visibility">
                <option value="public" {% if form.visibility != 'private' %}selected{% endif %}>{{ 'deck.public_visibility'|trans }}</option>
                <option value="private" {% if form.visibility == 'private' %}selected{% endif %}>{{ 'deck.private_visibility'|trans }}</option>
            </select>
        </label>

        <label>
            <span>{{ 'deck.description'|trans }}</span>
            <textarea name="description" rows="4" maxlength="4000">{{ form.description }}</textarea>
        </label>

        <section
            class="deck-builder"
            data-deck-builder
            data-search-url="{{ path('deck_card_search') }}"
            data-empty-text="{{ 'deck.builder.empty'|trans }}"
            data-no-results-text="{{ 'deck.builder.no_results'|trans }}"
            data-add-label="{{ 'deck.builder.add'|trans }}"
            data-remove-label="{{ 'deck.builder.remove'|trans }}"
        >
            <div class="deck-builder-controls">
                <label>
                    <span>{{ 'deck.builder.search'|trans }}</span>
                    <input type="search" data-deck-card-search placeholder="{{ 'deck.builder.search_placeholder'|trans }}" autocomplete="off">
                </label>

                <label>
                    <span>{{ 'deck.builder.collection'|trans }}</span>
                    <select data-deck-card-collection>
                        <option value="">{{ 'deck.builder.all_collections'|trans }}</option>
                        {% for collectionOption in collectionOptions|default([]) %}
                            <option value="{{ collectionOption.value }}">{{ collectionOption.label }}</option>
                        {% endfor %}
                    </select>
                </label>

                <label>
                    <span>{{ 'deck.builder.quantity'|trans }}</span>
                    <input type="number" min="1" max="99" value="4" data-deck-card-quantity>
                </label>

            </div>

            <div class="deck-builder-results" data-deck-card-results></div>

            <div class="deck-builder-list-shell">
                <h2>{{ 'deck.builder.selected'|trans }}</h2>
                <div class="deck-builder-list" data-deck-card-list></div>
            </div>

            <noscript>
                <label>
                    <span>{{ 'deck.decklist'|trans }}</span>
                    <textarea name="decklist" rows="14" placeholder="{{ 'deck.decklist_placeholder'|trans }}">{{ form.decklist }}</textarea>
                </label>
            </noscript>
        </section>

        <button type="submit">{{ 'deck.create'|trans }}</button>
    </form>
</section>
{% endblock %}
