{% extends 'base.html.twig' %}

{% block title %}Blog{% endblock %}

{% block body %}
<section class="home-hero">
    <p class="eyebrow">Blog</p>
    <h1>Choose a discussion room.</h1>
    <p>Pick a room, post with your name, and keep the conversation going in the database.</p>
</section>

<section class="topic-grid">
    {% for topic in topics %}
        <div class="detail-panel topic-card">
            <h2>{{ topic.title }}</h2>
            <p>{{ topic.description }}</p>
            <a class="card-detail-link" href="{{ path('blog_topic', { slug: topic.slug }) }}">Open discussion</a>
        </div>
    {% endfor %}
</section>
{% endblock %}
