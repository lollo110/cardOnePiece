{% extends 'base.html.twig' %}

{% block title %}{{ 'nav.blog'|trans }}{% endblock %}

{% block body %}
<section class="home-hero">
    <p class="eyebrow">{{ 'nav.blog'|trans }}</p>
    <h1>{{ 'blog.hero.title'|trans }}</h1>
    <p>{{ 'blog.hero.description'|trans }}</p>
</section>

<section class="topic-grid">
    {% for topic in topics %}
        <div class="detail-panel topic-card">
            <h2>{{ topic.title }}</h2>
            <p>{{ topic.description }}</p>
            <a class="card-detail-link" href="{{ path('blog_topic', { slug: topic.slug }) }}">{{ topic.button }}</a>
        </div>
    {% endfor %}
</section>
{% endblock %}
