{% extends 'base.html.twig' %}

{% block title %}Blog{% endblock %}

{% block body %}
<section class="home-hero">
    <p class="eyebrow">Blog</p>
    <h1>Choose a discussion room.</h1>
    <p>Trading and prices on one side, gameplay on the other.</p>
</section>

<section class="topic-grid">
    {% for topic in topics %}
        <div class="detail-panel topic-card" data-topic="{{ topic.slug }}">
            <h2>{{ topic.title }}</h2>
            <p>{{ topic.description }}</p>
            <a class="card-detail-link" href="{{ path('blog_topic', { slug: topic.slug }) }}">{{ topic.button }}</a>
        </div>
    {% endfor %}
</section>
{% endblock %}
