{% extends 'base.html.twig' %}

{% block title %}{{ 'auth.sign_up'|trans }}{% endblock %}

{% block body %}
<section class="auth-shell">
    <div class="detail-panel auth-panel">
        <p class="eyebrow">{{ 'auth.join'|trans }}</p>
        <h1>{{ 'auth.register.title'|trans }}</h1>
        <p class="muted">{{ 'auth.register.description'|trans }}</p>

        {{ form_start(registrationForm, { attr: { class: 'auth-form' } }) }}
            <div>
                {{ form_label(registrationForm.email) }}
                {{ form_widget(registrationForm.email, { attr: { placeholder: 'form.email_placeholder'|trans } }) }}
                {{ form_errors(registrationForm.email) }}
            </div>
            <div>
                {{ form_label(registrationForm.username) }}
                {{ form_widget(registrationForm.username, { attr: { placeholder: 'form.username_placeholder'|trans } }) }}
                {{ form_errors(registrationForm.username) }}
            </div>
            <div>
                {{ form_label(registrationForm.plainPassword) }}
                {{ form_widget(registrationForm.plainPassword, { attr: { placeholder: 'form.password_placeholder'|trans } }) }}
                {{ form_errors(registrationForm.plainPassword) }}
            </div>
            <button type="submit">{{ 'auth.sign_up'|trans }}</button>
        {{ form_end(registrationForm) }}

        <p class="auth-switch">{{ 'auth.register.switch'|trans }} <a href="{{ path('app_login') }}">{{ 'auth.sign_in'|trans }}</a></p>
    </div>
</section>
{% endblock %}
