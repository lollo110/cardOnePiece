{% extends 'base.html.twig' %}

{% block title %}Sign in{% endblock %}

{% block body %}
<section class="auth-shell">
    <div class="detail-panel auth-panel">
        <p class="eyebrow">Welcome back</p>
        <h1>Sign in</h1>
        <p class="muted">Use your email or username to access your account.</p>

        {% if error %}
            <p class="message message-error">{{ error.messageKey|trans(error.messageData, 'security') }}</p>
        {% endif %}

        <form method="post" class="auth-form">
            <label>
                Email or username
                <input type="text" name="_username" value="{{ lastUsername }}" autocomplete="username" required maxlength="180">
            </label>
            <label>
                Password
                <input type="password" name="_password" autocomplete="current-password" required>
            </label>
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
            <button type="submit">Sign in</button>
        </form>

        <p class="auth-switch">No account yet? <a href="{{ path('app_register') }}">Create one</a></p>
    </div>
</section>
{% endblock %}
