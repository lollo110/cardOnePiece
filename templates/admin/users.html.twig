{% extends 'base.html.twig' %}

{% block title %}{{ 'admin.users.title'|trans }}{% endblock %}

{% block body %}
<a class="back-link" href="{{ path('admin_dashboard') }}">{{ 'admin.back'|trans }}</a>

<section class="detail-panel">
    <p class="eyebrow">{{ 'admin.eyebrow'|trans }}</p>
    <h1>{{ 'admin.users.title'|trans }}</h1>
    <p class="muted">{{ 'admin.users.description'|trans }}</p>

    <div class="admin-table-wrap">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>{{ 'admin.users.username'|trans }}</th>
                    <th>{{ 'admin.users.email'|trans }}</th>
                    <th>{{ 'admin.users.roles'|trans }}</th>
                    <th>{{ 'admin.users.created'|trans }}</th>
                    <th>{{ 'admin.users.action'|trans }}</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                    {% set isAdmin = 'ROLE_ADMIN' in user.roles %}
                    <tr>
                        <td>{{ user.username }}</td>
                        <td>{{ user.email ?: 'common.na'|trans }}</td>
                        <td>
                            <span class="admin-role-badge{% if isAdmin %} is-admin{% endif %}">
                                {{ isAdmin ? 'admin.users.admin'|trans : 'admin.users.member'|trans }}
                            </span>
                        </td>
                        <td>{{ user.createdAt|date('Y-m-d') }}</td>
                        <td>
                            <form method="post" action="{{ path('admin_user_role', { id: user.id }) }}" class="admin-inline-form">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_user_role_' ~ user.id) }}">
                                {% if isAdmin %}
                                    <input type="hidden" name="action" value="remove_admin">
                                    <button type="submit">{{ 'admin.users.remove_admin'|trans }}</button>
                                {% else %}
                                    <input type="hidden" name="action" value="add_admin">
                                    <button type="submit">{{ 'admin.users.make_admin'|trans }}</button>
                                {% endif %}
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5">{{ 'admin.users.empty'|trans }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</section>
{% endblock %}
